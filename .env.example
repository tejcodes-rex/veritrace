# Veritrace configuration. Copy to .env and adjust as needed.
# Every value below has a working default for the bundled Docker stack,
# so a clean checkout runs with no edits.

# ---- Splunk connection ----
SPLUNK_HOST=localhost
SPLUNK_MGMT_PORT=8089
SPLUNK_HEC_PORT=8088
SPLUNK_WEB_PORT=8000
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=Veritrace!2026
SPLUNK_HEC_TOKEN=00000000-feed-feed-feed-000000000000
SPLUNK_VERIFY_TLS=false

# Index names used by Veritrace
SPLUNK_INDEX_SECURITY=security
SPLUNK_INDEX_LEDGER=veritrace_ledger
SPLUNK_INDEX_DETECTIONS=veritrace_detections

# ---- MCP server (splunk-mcp-server2 reference implementation) ----
# Veritrace reaches Splunk only through these MCP tools, never directly.
MCP_TRANSPORT=sse
MCP_URL=http://localhost:8052/sse
MCP_SPLUNK_HOST=splunk
MCP_SPLUNK_PORT=8089

# ---- Model provider ----
# One of: ollama | vllm | splunk_hosted | replay
# replay needs no GPU or network and is used by tests and the offline demo.
VERITRACE_MODEL_PROVIDER=replay
VERITRACE_MODEL_NAME=foundation-sec
VERITRACE_MODEL_TEMPERATURE=0.2

# ollama provider. The Foundation-Sec weights are pulled straight from Hugging
# Face. The Q4_K_M build (~5 GB) fits an 8 GB GPU; the official Q8_0 build is
# higher fidelity if you have the memory.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/mradermacher/Foundation-Sec-8B-Instruct-GGUF:Q4_K_M

# vllm / OpenAI-compatible provider
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=fdtn-ai/Foundation-Sec-1.1-8B-Instruct

# splunk_hosted provider (Splunk Cloud only, routed through the | ai SPL command)
SPLUNK_HOSTED_MODEL=foundation-sec-1.1-8b-instruct

# ---- Veritrace backend / console ----
VERITRACE_API_HOST=0.0.0.0
VERITRACE_API_PORT=8400
VERITRACE_CONSOLE_PORT=5173

# Response actions are proposed for human approval and never auto-executed
# unless this is explicitly set to true (not recommended for the demo).
VERITRACE_AUTO_RESPOND=false
